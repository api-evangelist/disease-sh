{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/disease-sh/main/json-schema/USPHL.json",
  "title": "USPHL",
  "properties": {
    "week": {
      "type": "string"
    },
    "A(H3N2v)": {
      "type": "number"
